# .env.example — copy to .env and fill in real values (never commit .env)

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...          # Required — get from console.anthropic.com
VOYAGE_API_KEY=pa-...                 # Required for embeddings — get from dash.voyageai.com

# === MODELS ===
CLAUDE_MODEL=claude-sonnet-4-5        # Main model for all agents
CLAUDE_VISION_MODEL=claude-opus-4-5  # Vision model for PDF image extraction
EMBEDDING_MODEL=voyage-3              # Embedding model

# === SERVER ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# === REDIS ===
REDIS_URL=redis://localhost:6379

# === STORAGE ===
VECTOR_STORE_PATH=./storage/vector_stores
UPLOADS_PATH=./storage/uploads
EXPORTS_PATH=./storage/exports

# === AUDIT AGENT ===
AUDIT_CHUNK_SIZE=1000
AUDIT_CHUNK_OVERLAP=200
AUDIT_RETRIEVAL_K=12

# === NEWS AGENT ===
NEWS_CHUNK_SIZE=1000
NEWS_CHUNK_OVERLAP=150

# === DATABASE (TalkToData) ===
# User provides these at runtime via UI — no hardcoded DB creds
